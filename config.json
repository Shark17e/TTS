{
  "hotkey": {
    "modifiers": ["ctrl", "shift"],
    "key": "space"
  },
  "whisper": {
    "model_size": "small",
    "model_dir": "whisper-models",
    "device": "cpu",
    "compute_type": "int8"
  },
  "audio": {
    "sample_rate": 16000,
    "silence_threshold": 0.03,
    "silence_duration_sec": 1.5,
    "min_duration_sec": 0.5,
    "max_duration_sec": 30
  }
}
